# ==========================================================
# trading-robot-lab .gitignore
# Protect secrets, private market data, binaries, databases,
# logs and generated development artifacts.
# ==========================================================

# Secrets and local environment
.env
.env.*
!.env.example
secrets/
private/
credentials/
*.key
*.pem
*.pfx
*.p12
*.crt
*.cer
*.ppk
id_rsa
id_rsa.*
id_ed25519
id_ed25519.*

# Tokens / sessions / authentication
*.token
*.session
*.cookies
cookies.txt
session.json
sessions/

# Logs and runtime output
*.log
logs/
runtime/
output/
tmp/
temp/

# Trading and private data
data/raw/
data/private/
data/live/
data/broker/
data/reports/
data/ticks/
data/orderbook/
*.qsh
*.pcap
*.pcapng
*.db
*.sqlite
*.sqlite3
*.duckdb
*.parquet
*.feather
*.h5
*.hdf5
*.csv

# Safe sample data exceptions
!data/README.md
!data/sample/
!data/sample/**
!*.sample.csv

# Archives
*.zip
*.rar
*.7z
*.tar
*.tar.gz
*.tgz
*.gz

# Executables and binary artifacts
*.exe
*.dll
*.msi
*.so
*.dylib
*.jar
*.bin
*.dat

# Scripts are denied by default.
*.bat
*.cmd
*.ps1

# Reviewed repository script exceptions.
!tools/*.ps1
!owner_review_packages/
!owner_review_packages/**/
!owner_review_packages/**/START_DEMO.cmd
!owner_review_packages/**/STOP_DEMO.cmd

# Python
__pycache__/
*.py[cod]
*$py.class
.venv/
venv/
env/
ENV/
.python-version
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
dist/
build/
*.egg-info/

# Node / frontend
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.next/

# Visual Studio / .NET
.vs/
[Bb]in/
[Oo]bj/
*.user
*.suo
*.userosscache
*.sln.docstates
TestResults/
packages/

# C / C++
*.o
*.obj
*.a
*.lib
*.out
*.app
cmake-build-*/
CMakeFiles/
CMakeCache.txt
compile_commands.json

# IDE and editor
.vscode/
.idea/
*.swp
*.swo
*.swn

# OS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
desktop.ini

# Keep placeholders
!.gitkeep
!README.md

# MiMo local files
.mimocode/
