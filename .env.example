# Safe example config. Do not put real secrets here.

TRADING_MODE=backtest
LIVE_TRADING_ENABLED=false

# Broker/exchange placeholders only. Real values must stay in local .env or server secrets.
BROKER_API_KEY=put_key_here
BROKER_API_SECRET=put_secret_here
BROKER_ACCOUNT_ID=put_account_id_here

# Risk limits for research/demo mode.
MAX_POSITION_ABS=1
MAX_ORDER_QTY=1
MAX_DAILY_LOSS=1000
MAX_ORDERS_PER_MINUTE=30

# Market data safety.
MAX_MARKET_DATA_STALENESS_MS=1000
MAX_ALLOWED_PRICE_DEVIATION_PCT=5

# Logging.
LOG_LEVEL=INFO
