{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "trading-robot-lab://schemas/strategy_signal/v1",
  "title": "StrategySignal",
  "description": "Output signal from a TradeAgent. Represents a trading decision before risk validation.",
  "version": "1.0.0",
  "type": "object",
  "required": [
    "signal_id",
    "timestamp_ns",
    "instrument_id",
    "strategy_id",
    "signal_type"
  ],
  "properties": {
    "signal_id": {
      "type": "string",
      "description": "Unique signal identifier."
    },
    "timestamp_ns": {
      "type": "integer",
      "description": "Signal generation timestamp in nanoseconds since Unix epoch."
    },
    "instrument_id": {
      "type": "string",
      "description": "Instrument identifier."
    },
    "strategy_id": {
      "type": "string",
      "description": "Strategy that generated this signal."
    },
    "strategy_version": {
      "type": "string",
      "description": "Version of the strategy."
    },
    "signal_type": {
      "type": "string",
      "enum": ["entry_long", "entry_short", "exit_long", "exit_short", "hold", "close_all"],
      "description": "Type of trading signal."
    },
    "signal_strength": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Signal strength from 0.0 (weak) to 1.0 (strong)."
    },
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0,
      "description": "Strategy confidence in this signal from 0.0 to 1.0."
    },
    "target_price": {
      "type": ["number", "null"],
      "description": "Desired entry/exit price. Null for market orders."
    },
    "target_quantity": {
      "type": ["integer", "null"],
      "description": "Desired quantity. Null if determined by risk/position sizing."
    },
    "order_type_hint": {
      "type": "string",
      "enum": ["limit", "market", "passive"],
      "default": "limit",
      "description": "Preferred order type."
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "normal", "high", "critical"],
      "default": "normal",
      "description": "Signal urgency level."
    },
    "features_used": {
      "type": "object",
      "description": "Snapshot of key feature values that produced this signal.",
      "additionalProperties": {
        "type": ["number", "null"]
      }
    },
    "reason": {
      "type": ["string", "null"],
      "description": "Human-readable reason for the signal."
    },
    "expires_at_ns": {
      "type": ["integer", "null"],
      "description": "Signal expiration timestamp in nanoseconds. Null if no expiration."
    }
  },
  "additionalProperties": false
}
